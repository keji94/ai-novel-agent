{
  "$schema": "https://openclaw.ai/schema/config.json",
  "version": "1.0.0",
  "name": "ai-novel-agent",
  "description": "AI网文写作智能体 - 基于OpenClaw多Agent架构",

  "model": {
    "default": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.7,
      "max_tokens": 8192
    },
    "planner": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.8,
      "max_tokens": 16384
    },
    "writer": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.9,
      "max_tokens": 16384
    },
    "editor": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-6",
      "temperature": 0.5,
      "max_tokens": 8192
    }
  },

  "agents": {
    "defaults": {
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.7,
          "max_tokens": 8192
        },
        "thinking": "basic",
        "maxConcurrent": 5,
        "archiveAfterMinutes": 60
      }
    },
    "ai-novel-agent": {
      "name": "网文写作智能体",
      "workspace": "workspace-ai-novel-agent/workspace-main",
      "description": "AI网文写作智能体入口，接收用户需求，分析任务类型，分发给对应的专业Agent",
      "enabled": true,
      "is_entry": true,
      "subagents": {
        "allowAgents": ["planner", "writer", "editor", "reviser", "chapter-analyzer", "style-analyzer", "detector", "analyst", "operator", "learner"]
      }
    },
    "planner": {
      "name": "策划/大纲师",
      "workspace": "workspace-ai-novel-agent/workspace-planner",
      "description": "世界观构建、角色设定、剧情大纲、章节规划",
      "enabled": true,
      "subagents": {
        "model": {
          "temperature": 0.8,
          "max_tokens": 16384
        }
      }
    },
    "writer": {
      "name": "写作/作者",
      "workspace": "workspace-ai-novel-agent/workspace-writer",
      "description": "正文撰写、场景描写、对话编写",
      "enabled": true,
      "subagents": {
        "model": {
          "temperature": 0.9,
          "max_tokens": 16384
        }
      }
    },
    "editor": {
      "name": "编辑/审核",
      "workspace": "workspace-ai-novel-agent/workspace-editor",
      "description": "内容审核、文字润色、一致性检查、格式规范",
      "enabled": true,
      "subagents": {
        "model": {
          "temperature": 0.5,
          "max_tokens": 8192
        }
      }
    },
    "analyst": {
      "name": "网文分析",
      "workspace": "workspace-ai-novel-agent/workspace-analyst",
      "description": "分析优秀网文的结构、风格、节奏、爽点设计",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.6,
          "max_tokens": 16384
        }
      }
    },
    "operator": {
      "name": "运营/分析",
      "workspace": "workspace-ai-novel-agent/workspace-operator",
      "description": "市场趋势分析、读者偏好研究、更新策略建议",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.7,
          "max_tokens": 8192
        }
      }
    },
    "learner": {
      "name": "写作技巧学习",
      "workspace": "workspace-ai-novel-agent/workspace-learner",
      "description": "学习写作技巧、总结最佳实践、提供写作指导",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.7,
          "max_tokens": 16384
        }
      }
    },
    "reviser": {
      "name": "修订者",
      "workspace": "workspace-ai-novel-agent/workspace-reviser",
      "description": "根据审计报告修复章节问题，支持5种修订模式：polish/spot-fix/rewrite/rework/anti-detect",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.3,
          "max_tokens": 8192
        }
      }
    },
    "chapter-analyzer": {
      "name": "章节分析器",
      "workspace": "workspace-ai-novel-agent/workspace-chapter-analyzer",
      "description": "从已有章节逆向工程生成真相文件，支持单文件导入、目录导入、断点续导",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.3,
          "max_tokens": 16384
        }
      }
    },
    "style-analyzer": {
      "name": "文风分析器",
      "workspace": "workspace-ai-novel-agent/workspace-style-analyzer",
      "description": "分析参考文本提取风格指纹，生成风格指南，支持风格应用到书籍",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.3,
          "max_tokens": 16384
        }
      }
    },
    "detector": {
      "name": "AI痕迹检测器",
      "workspace": "workspace-ai-novel-agent/workspace-detector",
      "description": "检测AI生成痕迹，支持11条确定性规则+语义分析，提供修订建议",
      "enabled": true,
      "subagents": {
        "model": {
          "provider": "anthropic",
          "model": "claude-sonnet-4-6",
          "temperature": 0.3,
          "max_tokens": 16384
        }
      }
    }
  },

  "bindings": [
    {
      "agentId": "ai-novel-agent",
      "match": {
        "channel": "feishu",
        "accountId": "main"
      }
    },
    {
      "agentId": "ai-novel-agent",
      "match": {
        "channel": "cli"
      }
    }
  ],

  "channels": {
    "feishu": {
      "enabled": false,
      "appId": "${FEISHU_APP_ID}",
      "appSecret": "${FEISHU_APP_SECRET}"
    },
    "cli": {
      "enabled": true
    }
  },

  "storage": {
    "basePath": "./novels"
  },

  "skills": {
    "ima-skill": {
      "path": "skills/ima-skill"
    }
  },

  "tools": {
    "subagents": {
      "tools": {
        "deny": ["gateway", "cron"]
      }
    }
  },

  "logging": {
    "level": "info",
    "file": "logs/openclaw.log"
  }
}
