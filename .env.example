# ============================================
# AI网文写作智能体 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
#
# 安装时自动加载: ./install.sh
# 也可通过环境变量覆盖: FEISHU_CHAT_ID=xxx ./install.sh
# ============================================

# ── 飞书渠道 ──────────────────────────────────
# 绑定飞书群组，使 Agent 自动响应该群消息
# 获取方式：飞书群设置 → 群机器人 → 查看群组 ID
FEISHU_CHAT_ID=
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=

# ── IMA 云端同步 ──────────────────────────────
# 腾讯 IMA 笔记本同步（可选）
# 获取方式：https://ima.qq.com/agent-interface
IMA_OPENAPI_CLIENTID=
IMA_OPENAPI_APIKEY=
